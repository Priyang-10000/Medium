                      {
                        "type": "svg",
                        "id": "tag264",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg viewBox=\"0 0 260 220\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%;overflow:visible;\">\n        <!-- Background reference bars -->\n        <line x1=\"30\" y1=\"20\" x2=\"240\" y2=\"20\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"30\" y1=\"55\" x2=\"240\" y2=\"55\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"30\" y1=\"90\" x2=\"240\" y2=\"90\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"30\" y1=\"125\" x2=\"240\" y2=\"125\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"30\" y1=\"160\" x2=\"240\" y2=\"160\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n\n        <!-- Cafe/retail: 45% = $2.25 - height 112 -->\n        <rect x=\"40\" y=\"48\" width=\"32\" height=\"112\" rx=\"5\" fill=\"#f5c87a\"></rect>\n        <text x=\"56\" y=\"42\" fill=\"#f5c87a\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\">$2.25</text>\n        <text x=\"56\" y=\"178\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">Cafe</text>\n        <text x=\"56\" y=\"189\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">(45%)</text>\n\n        <!-- Labor: 25% = $1.25 - height 62 -->\n        <rect x=\"87\" y=\"98\" width=\"32\" height=\"62\" rx=\"5\" fill=\"#8b5cf6\"></rect>\n        <text x=\"103\" y=\"92\" fill=\"#8b5cf6\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\">$1.25</text>\n        <text x=\"103\" y=\"178\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">Labor</text>\n        <text x=\"103\" y=\"189\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">(25%)</text>\n\n        <!-- Cup/supply: 12% - height 30 -->\n        <rect x=\"134\" y=\"130\" width=\"32\" height=\"30\" rx=\"5\" fill=\"#4a90d9\"></rect>\n        <text x=\"150\" y=\"124\" fill=\"#4a90d9\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\">$0.60</text>\n        <text x=\"150\" y=\"178\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">Supply</text>\n        <text x=\"150\" y=\"189\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">(12%)</text>\n\n        <!-- Milk: 8% = height 20 -->\n        <rect x=\"181\" y=\"140\" width=\"32\" height=\"20\" rx=\"5\" fill=\"#4caf7d\"></rect>\n        <text x=\"197\" y=\"134\" fill=\"#4caf7d\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\">$0.40</text>\n        <text x=\"197\" y=\"178\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">Milk</text>\n        <text x=\"197\" y=\"189\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">(8%)</text>\n\n        <!-- Coffee beans: 10% = height 25 -->\n        <rect x=\"213\" y=\"135\" width=\"32\" height=\"25\" rx=\"5\" fill=\"#c8703a\"></rect>\n        <text x=\"229\" y=\"129\" fill=\"#c8703a\" font-size=\"10\" font-weight=\"700\" text-anchor=\"middle\">$0.50</text>\n        <text x=\"229\" y=\"178\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">Beans</text>\n        <text x=\"229\" y=\"189\" fill=\"#9090a8\" font-size=\"9\" text-anchor=\"middle\">(10%)</text>\n\n        <!-- X axis -->\n        <line x1=\"30\" y1=\"160\" x2=\"255\" y2=\"160\" stroke=\"rgba(200,133,58,0.15)\" stroke-width=\"1\"></line>\n\n        <!-- Note -->\n        <text x=\"135\" y=\"210\" fill=\"#5a5a78\" font-size=\"9\" text-anchor=\"middle\">Farmer receives ~1–3% of retail price</text>\n      </svg>",
                        "record": 0,
