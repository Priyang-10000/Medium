                            "type": "svg",
                            "id": "tag92",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg width=\"100%\" height=\"240\" viewBox=\"0 0 900 240\" preserveAspectRatio=\"none\" style=\"flex:1; overflow:visible;\">\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#f5a623\" stop-opacity=\"0.35\"></stop>\n            <stop offset=\"100%\" stop-color=\"#f5a623\" stop-opacity=\"0.0\"></stop>\n          </linearGradient>\n          <linearGradient id=\"lineStroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0%\" stop-color=\"#c87028\"></stop>\n            <stop offset=\"100%\" stop-color=\"#f5a623\"></stop>\n          </linearGradient>\n        </defs>\n\n        <!-- Grid lines Y -->\n        <line x1=\"0\" y1=\"20\" x2=\"900\" y2=\"20\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"0\" y1=\"65\" x2=\"900\" y2=\"65\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"0\" y1=\"110\" x2=\"900\" y2=\"110\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"0\" y1=\"155\" x2=\"900\" y2=\"155\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"0\" y1=\"200\" x2=\"900\" y2=\"200\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\" stroke-dasharray=\"4,4\"></line>\n\n        <!-- Y labels -->\n        <text x=\"0\" y=\"17\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Space Grotesk, sans-serif\">180M</text>\n        <text x=\"0\" y=\"62\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Space Grotesk, sans-serif\">165M</text>\n        <text x=\"0\" y=\"107\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Space Grotesk, sans-serif\">150M</text>\n        <text x=\"0\" y=\"152\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Space Grotesk, sans-serif\">135M</text>\n        <text x=\"0\" y=\"197\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Space Grotesk, sans-serif\">120M</text>\n\n        <!-- Area fill -->\n        <!-- Data points mapped: 2000=105M, 2003=107, 2006=115, 2009=122, 2012=141, 2015=152, 2017=158, 2019=170, 2021=166, 2023=174 -->\n        <!-- Scale: 100M=240, 180M=0, so 1M = 3px. y = 240 - (val-100)*3 -->\n        <!-- x positions: 2000=60, 2023=880, step per year = (880-60)/23 = 35.65 -->\n        <path d=\"\n          M 60,405\n          L 60,195\n          L 166.9,189\n          L 273.8,165\n          L 380.7,141\n          L 487.6,93\n          L 594.5,60\n          L 665.5,42\n          L 736.5,0\n          L 807.5,12\n          L 880,0\n          L 880,405 Z\" fill=\"url(#lineGrad)\" transform=\"scale(1,0.55) translate(0,5)\"></path>\n\n        <!-- Line path -->\n        <polyline points=\"60,195 166.9,189 273.8,165 380.7,141 487.6,93 594.5,60 665.5,42 736.5,10 807.5,20 880,5\" fill=\"none\" stroke=\"url(#lineStroke)\" stroke-width=\"3\" stroke-linejoin=\"round\" stroke-linecap=\"round\"></polyline>\n\n        <!-- Data points dots -->\n        <circle cx=\"60\" cy=\"195\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"166.9\" cy=\"189\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"273.8\" cy=\"165\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"380.7\" cy=\"141\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"487.6\" cy=\"93\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"594.5\" cy=\"60\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"665.5\" cy=\"42\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"736.5\" cy=\"10\" r=\"5\" fill=\"#f5ef23\" stroke=\"#080c10\" stroke-width=\"2\" filter=\"url(#glow)\"></circle>\n        <circle cx=\"807.5\" cy=\"20\" r=\"5\" fill=\"#f5a623\" stroke=\"#080c10\" stroke-width=\"2\"></circle>\n        <circle cx=\"880\" cy=\"5\" r=\"7\" fill=\"#f5a623\" stroke=\"#f5a623\" stroke-width=\"3\" filter=\"url(#glow)\"></circle>\n\n        <!-- X labels -->\n        <text x=\"55\" y=\"225\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Inter,sans-serif\" text-anchor=\"middle\">2000</text>\n        <text x=\"273.8\" y=\"225\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Inter,sans-serif\" text-anchor=\"middle\">2006</text>\n        <text x=\"487.6\" y=\"225\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Inter,sans-serif\" text-anchor=\"middle\">2012</text>\n        <text x=\"665.5\" y=\"225\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Inter,sans-serif\" text-anchor=\"middle\">2017</text>\n        <text x=\"880\" y=\"225\" fill=\"#3a4858\" font-size=\"22\" font-family=\"Inter,sans-serif\" text-anchor=\"middle\">2023</text>\n\n        <!-- Tooltip for last point -->\n        <rect x=\"800\" y=\"0\" width=\"90\" height=\"36\" rx=\"6\" fill=\"rgba(245,166,35,0.15)\" stroke=\"rgba(245,166,35,0.3)\" stroke-width=\"1\"></rect>\n        <text x=\"845\" y=\"22\" fill=\"#f5a623\" font-size=\"20\" font-family=\"Space Grotesk,sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">174M</text>\n      </svg>",
