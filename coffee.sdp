                          {
                            "type": "svg",
                            "id": "tag223",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 460 280\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"healthBar\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n              <stop offset=\"0%\" style=\"stop-color:#4ade80\"></stop>\n              <stop offset=\"100%\" style=\"stop-color:#16a34a\"></stop>\n            </linearGradient>\n          </defs>\n          <!-- Grid -->\n          <line x1=\"50\" y1=\"20\" x2=\"50\" y2=\"220\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"220\" x2=\"450\" y2=\"220\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"180\" x2=\"450\" y2=\"180\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"140\" x2=\"450\" y2=\"140\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"100\" x2=\"450\" y2=\"100\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"60\" x2=\"450\" y2=\"60\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"20\" x2=\"450\" y2=\"20\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <!-- Y labels -->\n          <text x=\"42\" y=\"224\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">0%</text>\n          <text x=\"42\" y=\"184\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">10%</text>\n          <text x=\"42\" y=\"144\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">20%</text>\n          <text x=\"42\" y=\"104\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">30%</text>\n          <text x=\"42\" y=\"64\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">40%</text>\n          <text x=\"42\" y=\"24\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">50%</text>\n          <!-- Bars: T2D 25%, Parkinson's 32%, Liver Disease 40%, Alzheimer's 20%, Depression 8%, Stroke 20% -->\n          <!-- Y = 220 - (val/50)*200 -->\n          <!-- T2D 25%: 220-100=120, h=100 -->\n          <rect x=\"58\" y=\"120\" width=\"44\" height=\"100\" rx=\"3\" fill=\"url(#healthBar)\" opacity=\"0.9\"></rect>\n          <text x=\"80\" y=\"113\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">25%</text>\n          <text x=\"80\" y=\"236\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Type 2</text>\n          <text x=\"80\" y=\"246\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Diabetes</text>\n          <!-- Parkinson's 32%: 220-128=92, h=128 -->\n          <rect x=\"118\" y=\"92\" width=\"44\" height=\"128\" rx=\"3\" fill=\"url(#healthBar)\" opacity=\"0.85\"></rect>\n          <text x=\"140\" y=\"84\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">32%</text>\n          <text x=\"140\" y=\"236\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Parkinson's</text>\n          <text x=\"140\" y=\"246\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Disease</text>\n          <!-- Liver Disease 40%: 220-160=60, h=160 -->\n          <rect x=\"178\" y=\"60\" width=\"44\" height=\"160\" rx=\"3\" fill=\"url(#healthBar)\" opacity=\"0.95\"></rect>\n          <text x=\"200\" y=\"52\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">40%</text>\n          <text x=\"200\" y=\"236\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Liver</text>\n          <text x=\"200\" y=\"246\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Cirrhosis</text>\n          <!-- Alzheimer's 20%: 220-80=140, h=80 -->\n          <rect x=\"238\" y=\"140\" width=\"44\" height=\"80\" rx=\"3\" fill=\"url(#healthBar)\" opacity=\"0.8\"></rect>\n          <text x=\"260\" y=\"132\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">20%</text>\n          <text x=\"260\" y=\"236\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Alzheimer's</text>\n          <text x=\"260\" y=\"246\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Risk</text>\n          <!-- Depression 8%: 220-32=188, h=32 -->\n          <rect x=\"298\" y=\"188\" width=\"44\" height=\"32\" rx=\"3\" fill=\"url(#healthBar)\" opacity=\"0.7\"></rect>\n          <text x=\"320\" y=\"180\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">8%</text>\n          <text x=\"320\" y=\"236\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Depression</text>\n          <text x=\"320\" y=\"246\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Risk</text>\n          <!-- Stroke 20%: h=80 -->\n          <rect x=\"358\" y=\"140\" width=\"44\" height=\"80\" rx=\"3\" fill=\"url(#healthBar)\" opacity=\"0.8\"></rect>\n          <text x=\"380\" y=\"132\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">20%</text>\n          <text x=\"380\" y=\"236\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Stroke</text>\n          <text x=\"380\" y=\"246\" fill=\"#b8b4ae\" font-size=\"8.5\" text-anchor=\"middle\">Risk</text>\n\n          <!-- Note -->\n          <text x=\"50\" y=\"270\" fill=\"#6b7280\" font-size=\"9\">* Observational studies; 3–4 cups/day. Not medical advice.</text>\n        </svg>",
