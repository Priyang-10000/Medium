                        "dataset": "",
                        "field": "",
                        "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 1000 300\" xmlns=\"http://www.w3.org/2000/svg\" style=\"margin-top:16px;\">\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n            <stop offset=\"0%\" style=\"stop-color:#c8963e; stop-opacity:0.4\"></stop>\n            <stop offset=\"100%\" style=\"stop-color:#c8963e; stop-opacity:0\"></stop>\n          </linearGradient>\n          <linearGradient id=\"projGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n            <stop offset=\"0%\" style=\"stop-color:#60a5fa; stop-opacity:0.25\"></stop>\n            <stop offset=\"100%\" style=\"stop-color:#60a5fa; stop-opacity:0\"></stop>\n          </linearGradient>\n          <marker id=\"dot\" viewBox=\"0 0 10 10\" refX=\"5\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\">\n            <circle cx=\"5\" cy=\"5\" r=\"4\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n          </marker>\n          <marker id=\"dotProj\" viewBox=\"0 0 10 10\" refX=\"5\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\">\n            <circle cx=\"5\" cy=\"5\" r=\"4\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n          </marker>\n        </defs>\n        <!-- Grid -->\n        <line x1=\"70\" y1=\"20\" x2=\"70\" y2=\"240\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n        <line x1=\"70\" y1=\"240\" x2=\"970\" y2=\"240\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n        <line x1=\"70\" y1=\"200\" x2=\"970\" y2=\"200\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"70\" y1=\"160\" x2=\"970\" y2=\"160\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"70\" y1=\"120\" x2=\"970\" y2=\"120\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"70\" y1=\"80\" x2=\"970\" y2=\"80\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n        <line x1=\"70\" y1=\"40\" x2=\"970\" y2=\"40\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n        <!-- Y labels: 200, 300, 400, 500, 600, 700 → range 200-700, height 200px -->\n        <text x=\"62\" y=\"244\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"end\">$200B</text>\n        <text x=\"62\" y=\"204\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"end\">$300B</text>\n        <text x=\"62\" y=\"164\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"end\">$400B</text>\n        <text x=\"62\" y=\"124\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"end\">$500B</text>\n        <text x=\"62\" y=\"84\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"end\">$600B</text>\n        <text x=\"62\" y=\"44\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"end\">$700B</text>\n\n        <!-- Years: 2018(p1), 2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026, 2027, 2028, 2029, 2030 -->\n        <!-- Spacing: 900/12 = 75 each. X positions: 70, 145, 220, 295, 370, 445, 520, 595, 670, 745, 820, 895, 970 -->\n        <!-- Values: 340, 355, 330, 380, 430, 495, 530, 565, 600, 540, 580, 610, 624 -->\n        <!-- Y = 240 - (val-200)/500*200 -->\n        <!-- 340→96, 355→94, 330→104, 380→88, 430→76, 495→58, 530→52, 565→46, 600→40, 540→44... -->\n        <!-- Recompute: Y = 240 - (val-200)*(200/500) -->\n        <!-- 340: 240-56=184; 355: 240-62=178; 330: 240-52=188; 380: 240-72=168; 430: 240-92=148; 495: 240-118=122 -->\n        <!-- 530: 240-132=108; 565: 240-146=94; 600: 240-160=80; 540: 240-136=104... wait let me use 700 max -->\n        <!-- Y = 240 - (val-200)*(200/500) where 700 maps to 40, 200 maps to 240 -->\n        <!-- Actual: 2018=340, 2019=355, 2020=330, 2021=380, 2022=430, 2023=495 -->\n        <!-- Proj: 2023=495, 2024=530, 2025=565, 2026=600, 2027=545... let me keep simpler -->\n        <!-- 340→184, 355→178, 330→188, 380→168, 430→148, 495→122 -->\n        <!-- 530→108, 565→94, 600→80, 637→67.2→67, 679→56.4→56, 624→89.6→... -->\n        <!-- Let me use 2024=530, 2025=567, 2026=605, 2027=545 -->\n\n        <!-- Actual area fill -->\n        <polygon points=\"70,184 145,178 220,188 295,168 370,148 445,122 445,240 70,240\" fill=\"url(#lineGrad)\"></polygon>\n        <!-- Actual line -->\n        <polyline points=\"70,184 145,178 220,188 295,168 370,148 445,122\" fill=\"none\" stroke=\"#c8963e\" stroke-width=\"3\" stroke-linejoin=\"round\"></polyline>\n\n        <!-- Projected area fill (from 2023 onward) -->\n        <polygon points=\"445,122 520,108 595,94 670,80 745,67 820,55 895,44 895,240 445,240\" fill=\"url(#projGrad)\"></polygon>\n        <!-- Projected line -->\n        <polyline points=\"445,122 520,108 595,94 670,80 745,67 820,55 895,44\" fill=\"none\" stroke=\"#60a5fa\" stroke-width=\"3\" stroke-linejoin=\"round\" stroke-dasharray=\"8,4\"></polyline>\n\n        <!-- Data points actual -->\n        <circle cx=\"70\" cy=\"184\" r=\"5\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"145\" cy=\"178\" r=\"5\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"220\" cy=\"188\" r=\"5\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"295\" cy=\"168\" r=\"5\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"370\" cy=\"148\" r=\"5\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"445\" cy=\"122\" r=\"6\" fill=\"#f0c060\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n\n        <!-- Data point labels actual -->\n        <text x=\"70\" y=\"176\" fill=\"#f0c060\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$340B</text>\n        <text x=\"145\" y=\"170\" fill=\"#f0c060\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$355B</text>\n        <text x=\"220\" y=\"200\" fill=\"#fb7185\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$330B</text>\n        <text x=\"295\" y=\"160\" fill=\"#f0c060\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$380B</text>\n        <text x=\"370\" y=\"140\" fill=\"#f0c060\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$430B</text>\n        <text x=\"445\" y=\"114\" fill=\"#f0c060\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$495B</text>\n\n        <!-- Data points projected -->\n        <circle cx=\"520\" cy=\"108\" r=\"5\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"595\" cy=\"94\" r=\"5\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"670\" cy=\"80\" r=\"5\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"745\" cy=\"67\" r=\"5\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"820\" cy=\"55\" r=\"5\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n        <circle cx=\"895\" cy=\"44\" r=\"6\" fill=\"#60a5fa\" stroke=\"#1a1a26\" stroke-width=\"2\"></circle>\n\n        <!-- Projected labels -->\n        <text x=\"895\" y=\"36\" fill=\"#60a5fa\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$624B</text>\n\n        <!-- COVID annotation -->\n        <line x1=\"220\" y1=\"30\" x2=\"220\" y2=\"188\" stroke=\"#fb7185\" stroke-width=\"1\" stroke-dasharray=\"4,3\" opacity=\"0.6\"></line>\n        <text x=\"224\" y=\"38\" fill=\"#fb7185\" font-size=\"9\" font-weight=\"600\">COVID-19 dip</text>\n\n        <!-- X labels -->\n        <text x=\"70\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2018</text>\n        <text x=\"145\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2019</text>\n        <text x=\"220\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2020</text>\n        <text x=\"295\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2021</text>\n        <text x=\"370\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2022</text>\n        <text x=\"445\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2023</text>\n        <text x=\"520\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2024</text>\n        <text x=\"595\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2025</text>\n        <text x=\"670\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2026</text>\n        <text x=\"745\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2027</text>\n        <text x=\"820\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2028</text>\n        <text x=\"895\" y=\"258\" fill=\"#6b7280\" font-size=\"11\" text-anchor=\"middle\">2030</text>\n\n        <!-- Legend -->\n        <rect x=\"70\" y=\"275\" width=\"12\" height=\"3\" fill=\"#c8963e\" rx=\"1\"></rect>\n        <text x=\"88\" y=\"281\" fill=\"#b8b4ae\" font-size=\"10\">Actual</text>\n        <rect x=\"140\" y=\"273\" width=\"16\" height=\"3\" fill=\"#60a5fa\" rx=\"1\" stroke-dasharray=\"4,2\"></rect>\n        <line x1=\"140\" y1=\"275\" x2=\"156\" y2=\"275\" stroke=\"#60a5fa\" stroke-width=\"3\" stroke-dasharray=\"5,3\"></line>\n        <text x=\"162\" y=\"281\" fill=\"#b8b4ae\" font-size=\"10\">Projected</text>\n      </svg>",
