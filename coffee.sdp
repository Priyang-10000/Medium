                            "id": "tag138",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg width=\"160\" height=\"160\" viewBox=\"0 0 160 160\">\n          <!-- Donut: Arabica 63%, Robusta 34%, Others 3% -->\n          <!-- Total circumference of r=60: 2*PI*60 = 376.99 -->\n          <!-- Arabica: 376.99*0.63 = 237.5, offset=0 -->\n          <!-- Robusta: 376.99*0.34 = 128.2, offset=237.5 -->\n          <!-- Others:  376.99*0.03 = 11.3,  offset=365.7 -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#1a1a24\" stroke-width=\"28\"></circle>\n          <!-- Arabica -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#f0a030\" stroke-width=\"28\" stroke-dasharray=\"237.5 376.99\" stroke-dashoffset=\"0\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Robusta -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#8b4513\" stroke-width=\"28\" stroke-dasharray=\"128.2 376.99\" stroke-dashoffset=\"-237.5\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Others -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#3a3028\" stroke-width=\"28\" stroke-dasharray=\"11.3 376.99\" stroke-dashoffset=\"-365.7\" transform=\"rotate(-90 80 80)\"></circle>\n          <!-- Center text -->\n          <text x=\"80\" y=\"74\" fill=\"#f0a030\" font-size=\"20\" font-weight=\"900\" text-anchor=\"middle\">63%</text>\n          <text x=\"80\" y=\"90\" fill=\"#8a7a6a\" font-size=\"9\" text-anchor=\"middle\">Arabica</text>\n        </svg>",
