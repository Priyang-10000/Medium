                        "id": "tag38",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg class=\"vbar-chart\" viewBox=\"0 0 600 280\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"barGrad1\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#f5c87a\"></stop>\n            <stop offset=\"100%\" stop-color=\"#8b4a2f\"></stop>\n          </linearGradient>\n          <linearGradient id=\"barGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#e8a84e\"></stop>\n            <stop offset=\"100%\" stop-color=\"#6b3a2a\"></stop>\n          </linearGradient>\n          <linearGradient id=\"barGrad3\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#c8853a\"></stop>\n            <stop offset=\"100%\" stop-color=\"#4a2a1a\"></stop>\n          </linearGradient>\n        </defs>\n\n        <!-- Grid lines -->\n        <line x1=\"50\" y1=\"20\" x2=\"580\" y2=\"20\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"60\" x2=\"580\" y2=\"60\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"100\" x2=\"580\" y2=\"100\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"140\" x2=\"580\" y2=\"140\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"180\" x2=\"580\" y2=\"180\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"220\" x2=\"580\" y2=\"220\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n\n        <!-- Y-axis labels -->\n        <text x=\"40\" y=\"24\" fill=\"#5a5a78\" font-size=\"11\" text-anchor=\"end\">75</text>\n        <text x=\"40\" y=\"64\" fill=\"#5a5a78\" font-size=\"11\" text-anchor=\"end\">60</text>\n        <text x=\"40\" y=\"104\" fill=\"#5a5a78\" font-size=\"11\" text-anchor=\"end\">45</text>\n        <text x=\"40\" y=\"144\" fill=\"#5a5a78\" font-size=\"11\" text-anchor=\"end\">30</text>\n        <text x=\"40\" y=\"184\" fill=\"#5a5a78\" font-size=\"11\" text-anchor=\"end\">15</text>\n        <text x=\"40\" y=\"224\" fill=\"#5a5a78\" font-size=\"11\" text-anchor=\"end\">0</text>\n\n        <!-- Brazil: 66M -->\n        <rect x=\"65\" y=\"44\" width=\"62\" height=\"176\" rx=\"6\" fill=\"url(#barGrad1)\"></rect>\n        <text x=\"96\" y=\"38\" fill=\"#f5c87a\" font-size=\"12\" font-weight=\"700\" text-anchor=\"middle\">66M</text>\n        <text x=\"96\" y=\"242\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\">🇧🇷 Brazil</text>\n\n        <!-- Vietnam: 30M -->\n        <rect x=\"145\" y=\"124\" width=\"62\" height=\"96\" rx=\"6\" fill=\"url(#barGrad2)\"></rect>\n        <text x=\"176\" y=\"118\" fill=\"#e8a84e\" font-size=\"12\" font-weight=\"700\" text-anchor=\"middle\">30M</text>\n        <text x=\"176\" y=\"242\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\">🇻🇳 Vietnam</text>\n\n        <!-- Colombia: 14M -->\n        <rect x=\"225\" y=\"176\" width=\"62\" height=\"44\" rx=\"6\" fill=\"url(#barGrad3)\"></rect>\n        <text x=\"256\" y=\"170\" fill=\"#c8853a\" font-size=\"12\" font-weight=\"700\" text-anchor=\"middle\">14M</text>\n        <text x=\"256\" y=\"242\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\">🇨🇴 Colombia</text>\n\n        <!-- Indonesia: 12M -->\n        <rect x=\"305\" y=\"182\" width=\"62\" height=\"38\" rx=\"6\" fill=\"url(#barGrad3)\" opacity=\"0.85\"></rect>\n        <text x=\"336\" y=\"176\" fill=\"#c8853a\" font-size=\"12\" font-weight=\"700\" text-anchor=\"middle\">12M</text>\n        <text x=\"336\" y=\"242\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\">🇮🇩 Indonesia</text>\n\n        <!-- Ethiopia: 8M -->\n        <rect x=\"385\" y=\"195\" width=\"62\" height=\"25\" rx=\"6\" fill=\"url(#barGrad3)\" opacity=\"0.7\"></rect>\n        <text x=\"416\" y=\"189\" fill=\"#c8853a\" font-size=\"12\" font-weight=\"700\" text-anchor=\"middle\">8M</text>\n        <text x=\"416\" y=\"242\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\">🇪🇹 Ethiopia</text>\n\n        <!-- Honduras: 6M -->\n        <rect x=\"465\" y=\"201\" width=\"62\" height=\"19\" rx=\"6\" fill=\"url(#barGrad3)\" opacity=\"0.55\"></rect>\n        <text x=\"496\" y=\"195\" fill=\"#9090a8\" font-size=\"12\" font-weight=\"700\" text-anchor=\"middle\">6M</text>\n        <text x=\"496\" y=\"242\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\">🇭🇳 Honduras</text>\n\n        <!-- X-axis line -->\n        <line x1=\"50\" y1=\"220\" x2=\"580\" y2=\"220\" stroke=\"rgba(200,133,58,0.2)\" stroke-width=\"1\"></line>\n      </svg>",
