                            "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 420 240\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"tG1\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#f0c060\"></stop><stop offset=\"100%\" style=\"stop-color:#c8963e\"></stop></linearGradient>\n            <linearGradient id=\"tG2\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#60a5fa\"></stop><stop offset=\"100%\" style=\"stop-color:#2563eb\"></stop></linearGradient>\n            <linearGradient id=\"tG3\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#4ade80\"></stop><stop offset=\"100%\" style=\"stop-color:#16a34a\"></stop></linearGradient>\n            <linearGradient id=\"tG4\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#a78bfa\"></stop><stop offset=\"100%\" style=\"stop-color:#7c3aed\"></stop></linearGradient>\n          </defs>\n          <line x1=\"50\" y1=\"20\" x2=\"50\" y2=\"195\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"195\" x2=\"410\" y2=\"195\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"155\" x2=\"410\" y2=\"155\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"115\" x2=\"410\" y2=\"115\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"75\" x2=\"410\" y2=\"75\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <line x1=\"50\" y1=\"35\" x2=\"410\" y2=\"35\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"3,3\"></line>\n          <text x=\"42\" y=\"199\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">$0</text>\n          <text x=\"42\" y=\"159\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">$10B</text>\n          <text x=\"42\" y=\"119\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">$20B</text>\n          <text x=\"42\" y=\"79\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">$30B</text>\n          <text x=\"42\" y=\"39\" fill=\"#6b7280\" font-size=\"9\" text-anchor=\"end\">$40B</text>\n          <!-- Green beans: $38B → h=152 -->\n          <rect x=\"60\" y=\"43\" width=\"70\" height=\"152\" rx=\"4\" fill=\"url(#tG1)\"></rect>\n          <text x=\"95\" y=\"35\" fill=\"#f0c060\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$38B</text>\n          <text x=\"95\" y=\"213\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Green Beans</text>\n          <!-- Roasted: $22B → h=88 -->\n          <rect x=\"160\" y=\"107\" width=\"70\" height=\"88\" rx=\"4\" fill=\"url(#tG2)\"></rect>\n          <text x=\"195\" y=\"99\" fill=\"#60a5fa\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$22B</text>\n          <text x=\"195\" y=\"213\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Roasted</text>\n          <!-- Instant: $14B → h=56 -->\n          <rect x=\"260\" y=\"139\" width=\"70\" height=\"56\" rx=\"4\" fill=\"url(#tG3)\"></rect>\n          <text x=\"295\" y=\"131\" fill=\"#4ade80\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$14B</text>\n          <text x=\"295\" y=\"213\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Instant</text>\n          <!-- Other/Extract: $8B → h=32 -->\n          <rect x=\"340\" y=\"163\" width=\"62\" height=\"32\" rx=\"4\" fill=\"url(#tG4)\"></rect>\n          <text x=\"371\" y=\"155\" fill=\"#a78bfa\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$8B</text>\n          <text x=\"371\" y=\"213\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Extracts</text>\n        </svg>",
