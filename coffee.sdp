                                "id": "tag70",
                                "dataset": "",
                                "field": "",
                                "svgText": "<svg width=\"160\" height=\"160\" viewBox=\"0 0 160 160\">\n          <defs>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"></feGaussianBlur>\n              <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n            </filter>\n          </defs>\n          <!-- Background ring -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"28\"></circle>\n          <!-- Arabica: 60% = 216deg stroke -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#f5a623\" stroke-width=\"28\" stroke-dasharray=\"226.2 150.8\" stroke-dashoffset=\"56.5\" stroke-linecap=\"butt\" filter=\"url(#glow)\" opacity=\"0.9\"></circle>\n          <!-- Robusta: 37% = 133deg -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#3b82f6\" stroke-width=\"28\" stroke-dasharray=\"139.5 237.5\" stroke-dashoffset=\"-169.6\" stroke-linecap=\"butt\" opacity=\"0.85\"></circle>\n          <!-- Liberica: 3% = ~11deg -->\n          <circle cx=\"80\" cy=\"80\" r=\"60\" fill=\"none\" stroke=\"#10b981\" stroke-width=\"28\" stroke-dasharray=\"11.3 365.7\" stroke-dashoffset=\"-309.1\" stroke-linecap=\"butt\" opacity=\"0.85\"></circle>\n          <!-- Center text -->\n          <circle cx=\"80\" cy=\"80\" r=\"44\" fill=\"#0d1117\"></circle>\n          <text x=\"80\" y=\"74\" text-anchor=\"middle\" fill=\"#f5a623\" font-size=\"22\" font-weight=\"bold\" font-family=\"Space Grotesk, sans-serif\">60%</text>\n          <text x=\"80\" y=\"90\" text-anchor=\"middle\" fill=\"#5a6878\" font-size=\"11\" font-family=\"Inter, sans-serif\">Arabica</text>\n        </svg>",
