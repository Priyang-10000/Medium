                        "svgText": "<svg width=\"120\" height=\"120\" viewBox=\"0 0 120 120\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <!-- Steam -->\n        <path d=\"M38 24 C38 18, 44 18, 44 12 C44 6, 38 6, 38 0\" stroke=\"#c8853a\" stroke-width=\"2.5\" stroke-linecap=\"round\" fill=\"none\" opacity=\"0.6\">\n          <animate attributeName=\"opacity\" values=\"0.6;0.2;0.6\" dur=\"2s\" repeatCount=\"indefinite\"></animate>\n        </path>\n        <path d=\"M54 22 C54 16, 60 16, 60 10 C60 4, 54 4, 54 0\" stroke=\"#c8853a\" stroke-width=\"2.5\" stroke-linecap=\"round\" fill=\"none\" opacity=\"0.5\">\n          <animate attributeName=\"opacity\" values=\"0.5;0.1;0.5\" dur=\"2.4s\" repeatCount=\"indefinite\"></animate>\n        </path>\n        <path d=\"M70 24 C70 18, 76 18, 76 12 C76 6, 70 6, 70 0\" stroke=\"#c8853a\" stroke-width=\"2.5\" stroke-linecap=\"round\" fill=\"none\" opacity=\"0.6\">\n          <animate attributeName=\"opacity\" values=\"0.6;0.2;0.6\" dur=\"1.8s\" repeatCount=\"indefinite\"></animate>\n        </path>\n        <!-- Cup body -->\n        <path d=\"M18 40 L26 100 Q28 108 36 108 L84 108 Q92 108 94 100 L102 40 Z\" fill=\"#1a1a26\" stroke=\"#c8853a\" stroke-width=\"1.5\"></path>\n        <!-- Coffee liquid -->\n        <ellipse cx=\"60\" cy=\"52\" rx=\"38\" ry=\"10\" fill=\"#6b3a2a\"></ellipse>\n        <ellipse cx=\"60\" cy=\"50\" rx=\"36\" ry=\"8\" fill=\"#8b4a2f\"></ellipse>\n        <!-- Foam circle -->\n        <circle cx=\"52\" cy=\"49\" r=\"4\" fill=\"#c8853a\" opacity=\"0.4\"></circle>\n        <circle cx=\"64\" cy=\"47\" r=\"3\" fill=\"#c8853a\" opacity=\"0.3\"></circle>\n        <circle cx=\"60\" cy=\"54\" r=\"2.5\" fill=\"#c8853a\" opacity=\"0.25\"></circle>\n        <!-- Saucer -->\n        <ellipse cx=\"60\" cy=\"112\" rx=\"52\" ry=\"8\" fill=\"#12121a\" stroke=\"#c8853a\" stroke-width=\"1\" opacity=\"0.7\"></ellipse>\n        <!-- Handle -->\n        <path d=\"M102 56 Q120 56 120 72 Q120 88 102 88\" stroke=\"#c8853a\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"></path>\n      </svg>",
