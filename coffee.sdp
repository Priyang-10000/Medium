                      {
                        "type": "svg",
                        "id": "tag133",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"100%\" height=\"200\" viewBox=\"0 0 500 200\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#f0a030\" stop-opacity=\"0.3\"></stop>\n            <stop offset=\"100%\" stop-color=\"#f0a030\" stop-opacity=\"0.0\"></stop>\n          </linearGradient>\n        </defs>\n        <!-- Grid lines -->\n        <line x1=\"40\" y1=\"20\" x2=\"490\" y2=\"20\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"60\" x2=\"490\" y2=\"60\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"100\" x2=\"490\" y2=\"100\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"140\" x2=\"490\" y2=\"140\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"180\" x2=\"490\" y2=\"180\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <!-- Y axis labels -->\n        <text x=\"32\" y=\"24\" fill=\"#4a3a2a\" font-size=\"9\" text-anchor=\"end\">600</text>\n        <text x=\"32\" y=\"64\" fill=\"#4a3a2a\" font-size=\"9\" text-anchor=\"end\">500</text>\n        <text x=\"32\" y=\"104\" fill=\"#4a3a2a\" font-size=\"9\" text-anchor=\"end\">400</text>\n        <text x=\"32\" y=\"144\" fill=\"#4a3a2a\" font-size=\"9\" text-anchor=\"end\">300</text>\n        <text x=\"32\" y=\"184\" fill=\"#4a3a2a\" font-size=\"9\" text-anchor=\"end\">200</text>\n        <!-- Data points: 2015=212, 2016=225, 2017=242, 2018=266, 2019=302, 2020=318, 2021=353, 2022=399, 2023=495, 2024(est)=540 -->\n        <!-- Scale: 200-600 range = 160 units span mapped to 160px (y=180 for 200, y=20 for 600) -->\n        <!-- formula: y = 180 - (val-200)/400*160 -->\n        <!-- 212 -> 175.2, 225->170, 242->163.2, 266->152.8, 302->139.2, 318->132.8, 353->118.8, 399->100.4, 495->58, 540->36 -->\n        <!-- x positions: 40 to 490, 9 gaps for 10 points: step=50 -->\n        <path d=\"M40,175 L95,170 L150,163 L205,153 L260,139 L315,133 L370,119 L425,100 L480,58\" fill=\"none\" stroke=\"#f0a030\" stroke-width=\"2.5\" stroke-linejoin=\"round\"></path>\n        <!-- Area fill -->\n        <path d=\"M40,175 L95,170 L150,163 L205,153 L260,139 L315,133 L370,119 L425,100 L480,58 L480,180 L40,180 Z\" fill=\"url(#lineGrad)\"></path>\n        <!-- Dots -->\n        <circle cx=\"40\" cy=\"175\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"95\" cy=\"170\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"150\" cy=\"163\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"205\" cy=\"153\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"260\" cy=\"139\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"315\" cy=\"133\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"370\" cy=\"119\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"425\" cy=\"100\" r=\"4\" fill=\"#f0a030\"></circle>\n        <circle cx=\"480\" cy=\"58\" r=\"5\" fill=\"#fff\" stroke=\"#f0a030\" stroke-width=\"2\"></circle>\n        <!-- Value label for last point -->\n        <text x=\"480\" y=\"48\" fill=\"#f0a030\" font-size=\"10\" text-anchor=\"middle\" font-weight=\"700\">$495B</text>\n        <!-- X labels -->\n        <text x=\"40\" y=\"196\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2015</text>\n        <text x=\"150\" y=\"196\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2017</text>\n        <text x=\"260\" y=\"196\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2019</text>\n        <text x=\"370\" y=\"196\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2021</text>\n        <text x=\"480\" y=\"196\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2023</text>\n      </svg>",
                        "record": 0,
