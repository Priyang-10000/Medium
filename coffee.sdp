                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"200\" height=\"200\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <!-- Cup -->\n      <rect x=\"45\" y=\"100\" width=\"110\" height=\"75\" rx=\"10\" fill=\"rgba(139,90,43,0.25)\" stroke=\"rgba(200,120,40,0.5)\" stroke-width=\"2\"></rect>\n      <!-- Coffee liquid -->\n      <rect x=\"50\" y=\"108\" width=\"100\" height=\"30\" rx=\"4\" fill=\"rgba(100,55,20,0.6)\"></rect>\n      <!-- Liquid shine -->\n      <ellipse cx=\"100\" cy=\"123\" rx=\"40\" ry=\"8\" fill=\"rgba(245,166,35,0.08)\"></ellipse>\n      <!-- Cup handle -->\n      <path d=\"M155 115 Q185 115 185 140 Q185 160 155 160\" stroke=\"rgba(200,120,40,0.5)\" stroke-width=\"6\" fill=\"none\" stroke-linecap=\"round\"></path>\n      <!-- Saucer -->\n      <ellipse cx=\"100\" cy=\"178\" rx=\"68\" ry=\"10\" fill=\"rgba(139,90,43,0.2)\" stroke=\"rgba(200,120,40,0.3)\" stroke-width=\"1.5\"></ellipse>\n      <!-- Steam lines -->\n      <path d=\"M75 92 Q80 80 75 68\" stroke=\"rgba(245,166,35,0.4)\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"></path>\n      <path d=\"M100 88 Q105 76 100 62\" stroke=\"rgba(245,166,35,0.5)\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"></path>\n      <path d=\"M125 92 Q130 80 125 68\" stroke=\"rgba(245,166,35,0.4)\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"></path>\n      <!-- Coffee beans decorative -->\n      <ellipse cx=\"35\" cy=\"55\" rx=\"14\" ry=\"9\" fill=\"rgba(139,90,43,0.4)\" stroke=\"rgba(200,120,40,0.3)\" stroke-width=\"1.5\" transform=\"rotate(-30 35 55)\"></ellipse>\n      <line x1=\"35\" y1=\"46\" x2=\"35\" y2=\"64\" stroke=\"rgba(200,120,40,0.4)\" stroke-width=\"1\" transform=\"rotate(-30 35 55)\"></line>\n      <ellipse cx=\"165\" cy=\"45\" rx=\"14\" ry=\"9\" fill=\"rgba(139,90,43,0.4)\" stroke=\"rgba(200,120,40,0.3)\" stroke-width=\"1.5\" transform=\"rotate(20 165 45)\"></ellipse>\n      <line x1=\"165\" y1=\"36\" x2=\"165\" y2=\"54\" stroke=\"rgba(200,120,40,0.4)\" stroke-width=\"1\" transform=\"rotate(20 165 45)\"></line>\n      <!-- Top circle glow -->\n      <circle cx=\"100\" cy=\"100\" r=\"95\" fill=\"none\" stroke=\"rgba(200,120,40,0.08)\" stroke-width=\"1\"></circle>\n    </svg>",
