                            "field": "",
                            "svgText": "<svg width=\"200\" height=\"200\" viewBox=\"0 0 200 200\" xmlns=\"http://www.w3.org/2000/svg\">\n          <!-- Espresso/variants 35% = 153.9 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#1a1a26\" stroke-width=\"32\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#e8a84e\" stroke-width=\"32\" stroke-dasharray=\"153.9 285.9\" stroke-dashoffset=\"0\" transform=\"rotate(-90 100 100)\"></circle>\n          <!-- Filter/Drip 28% = 123.1 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#8b5cf6\" stroke-width=\"32\" stroke-dasharray=\"123.1 316.7\" stroke-dashoffset=\"-153.9\" transform=\"rotate(-90 100 100)\"></circle>\n          <!-- Cold brew/Iced 18% = 79.2 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#4a90d9\" stroke-width=\"32\" stroke-dasharray=\"79.2 360.6\" stroke-dashoffset=\"-277\" transform=\"rotate(-90 100 100)\"></circle>\n          <!-- Capsule 12% = 52.8 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#c8853a\" stroke-width=\"32\" stroke-dasharray=\"52.8 387\" stroke-dashoffset=\"-356.2\" transform=\"rotate(-90 100 100)\"></circle>\n          <!-- Other 7% = 30.8 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#5a5a78\" stroke-width=\"32\" stroke-dasharray=\"30.8 409\" stroke-dashoffset=\"-409\" transform=\"rotate(-90 100 100)\"></circle>\n\n          <circle cx=\"100\" cy=\"100\" r=\"54\" fill=\"#12121a\"></circle>\n          <text x=\"100\" y=\"94\" fill=\"#e8a84e\" font-size=\"26\" font-weight=\"900\" text-anchor=\"middle\" font-family=\"Inter\">35%</text>\n          <text x=\"100\" y=\"112\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\" font-family=\"Inter\">Espresso</text>\n        </svg>",
                            "record": 0,
                            "unique": true,
                            "filtered": true,
                            "isFilter": false,
                            "link": "",
