                      {
                        "type": "svg",
                        "id": "tag18",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"200\" height=\"220\" viewBox=\"0 0 200 220\" xmlns=\"http://www.w3.org/2000/svg\">\n        <!-- Steam -->\n        <path d=\"M70 50 Q65 35 70 20 Q75 5 70 -10\" stroke=\"#c8963e\" stroke-width=\"2.5\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.5\">\n          <animate attributeName=\"opacity\" values=\"0.5;0.9;0.5\" dur=\"2s\" repeatCount=\"indefinite\"></animate>\n        </path>\n        <path d=\"M90 45 Q85 28 90 12 Q95 -4 90 -18\" stroke=\"#c8963e\" stroke-width=\"2.5\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.4\">\n          <animate attributeName=\"opacity\" values=\"0.4;0.8;0.4\" dur=\"2.5s\" repeatCount=\"indefinite\"></animate>\n        </path>\n        <path d=\"M110 48 Q105 32 110 16 Q115 0 110 -14\" stroke=\"#c8963e\" stroke-width=\"2.5\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.45\">\n          <animate attributeName=\"opacity\" values=\"0.45;0.85;0.45\" dur=\"1.8s\" repeatCount=\"indefinite\"></animate>\n        </path>\n        <!-- Saucer -->\n        <ellipse cx=\"100\" cy=\"195\" rx=\"75\" ry=\"12\" fill=\"#2a1f10\" stroke=\"#c8963e\" stroke-width=\"1.5\"></ellipse>\n        <!-- Cup body -->\n        <path d=\"M40 90 L55 175 Q55 185 65 185 L135 185 Q145 185 145 175 L160 90 Z\" fill=\"#1e1408\" stroke=\"#c8963e\" stroke-width=\"2\"></path>\n        <!-- Cup gradient fill -->\n        <path d=\"M42 95 L56 172 Q56 182 65 182 L135 182 Q144 182 144 172 L158 95 Z\" fill=\"url(#cupGrad)\"></path>\n        <!-- Coffee surface -->\n        <ellipse cx=\"100\" cy=\"90\" rx=\"60\" ry=\"10\" fill=\"#3d2510\" stroke=\"#c8963e\" stroke-width=\"2\"></ellipse>\n        <!-- Coffee liquid -->\n        <ellipse cx=\"100\" cy=\"90\" rx=\"58\" ry=\"8\" fill=\"#6b3c1a\"></ellipse>\n        <!-- Latte art swirl -->\n        <path d=\"M100 90 Q110 84 115 90 Q110 96 100 90 Q90 84 85 90 Q90 96 100 90\" fill=\"none\" stroke=\"#d4a96a\" stroke-width=\"1.5\" opacity=\"0.7\"></path>\n        <!-- Handle -->\n        <path d=\"M158 110 Q185 110 185 135 Q185 160 158 160\" fill=\"none\" stroke=\"#c8963e\" stroke-width=\"8\" stroke-linecap=\"round\"></path>\n        <path d=\"M158 118 Q177 118 177 135 Q177 152 158 152\" fill=\"none\" stroke=\"#1e1408\" stroke-width=\"4\" stroke-linecap=\"round\"></path>\n        <!-- Rim highlight -->\n        <path d=\"M40 90 Q100 80 160 90\" fill=\"none\" stroke=\"#e8b84b\" stroke-width=\"1\" opacity=\"0.5\"></path>\n        <defs>\n          <linearGradient id=\"cupGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n            <stop offset=\"0%\" style=\"stop-color:#2d1a08\"></stop>\n            <stop offset=\"100%\" style=\"stop-color:#1a0e05\"></stop>\n          </linearGradient>\n        </defs>\n      </svg>",
