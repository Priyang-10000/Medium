                        "id": "tag306",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"100%\" height=\"180\" viewBox=\"0 0 500 180\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n          <linearGradient id=\"priceGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#c17314\" stop-opacity=\"0.35\"></stop>\n            <stop offset=\"100%\" stop-color=\"#c17314\" stop-opacity=\"0.0\"></stop>\n          </linearGradient>\n        </defs>\n        <line x1=\"40\" y1=\"20\" x2=\"490\" y2=\"20\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"60\" x2=\"490\" y2=\"60\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"100\" x2=\"490\" y2=\"100\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"140\" x2=\"490\" y2=\"140\" stroke=\"#1e2028\" stroke-width=\"1\"></line>\n        <text x=\"32\" y=\"23\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"end\">$3.5</text>\n        <text x=\"32\" y=\"63\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"end\">$2.5</text>\n        <text x=\"32\" y=\"103\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"end\">$1.5</text>\n        <text x=\"32\" y=\"143\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"end\">$0.5</text>\n        <!-- Price data 2018-2024: 1.15, 1.20, 1.05, 1.35, 2.20, 2.40, 1.80 -->\n        <!-- Scale: 0-3.5, range=3.5, height=120px (20-140), formula: y=140-(val/3.5)*120 -->\n        <!-- 1.15->100.4, 1.20->99, 1.05->104, 1.35->93.7, 2.20->67.4, 2.40->61.7, 1.80->81.7 -->\n        <!-- x: 40,115,190,265,340,415,490 (step=75) -->\n        <path d=\"M40,100 L115,99 L190,104 L265,94 L340,67 L415,62 L490,82\" fill=\"none\" stroke=\"#c17314\" stroke-width=\"2.5\" stroke-linejoin=\"round\"></path>\n        <path d=\"M40,100 L115,99 L190,104 L265,94 L340,67 L415,62 L490,82 L490,140 L40,140 Z\" fill=\"url(#priceGrad)\"></path>\n        <circle cx=\"40\" cy=\"100\" r=\"3.5\" fill=\"#c17314\"></circle>\n        <circle cx=\"115\" cy=\"99\" r=\"3.5\" fill=\"#c17314\"></circle>\n        <circle cx=\"190\" cy=\"104\" r=\"3.5\" fill=\"#c17314\"></circle>\n        <circle cx=\"265\" cy=\"94\" r=\"3.5\" fill=\"#c17314\"></circle>\n        <circle cx=\"340\" cy=\"67\" r=\"3.5\" fill=\"#c17314\"></circle>\n        <circle cx=\"415\" cy=\"62\" r=\"3.5\" fill=\"#fff\" stroke=\"#c17314\" stroke-width=\"2\"></circle>\n        <text x=\"415\" y=\"52\" fill=\"#f0a030\" font-size=\"9\" text-anchor=\"middle\" font-weight=\"700\">$2.40</text>\n        <circle cx=\"490\" cy=\"82\" r=\"3.5\" fill=\"#c17314\"></circle>\n        <text x=\"40\" y=\"158\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2018</text>\n        <text x=\"190\" y=\"158\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2020</text>\n        <text x=\"340\" y=\"158\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2022</text>\n        <text x=\"490\" y=\"158\" fill=\"#4a3a2a\" font-size=\"8\" text-anchor=\"middle\">2024</text>\n      </svg>",
