                        "idTitle": "",
                        "backgroundColor": "rgba(0, 0, 0, 0)",
                        "boxSizing": "border-box",
                        "customBackground": "rgba(0, 0, 0, 0) none repeat scroll 0% 0% / auto padding-box border-box",
                        "useCustomBackground": true,
                        "borderWidth": 0,
