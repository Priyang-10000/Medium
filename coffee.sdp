                      {
                        "type": "svg",
                        "id": "tag128",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg class=\"line-chart-wrap\" viewBox=\"0 0 580 240\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"lineArea\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#c8853a\" stop-opacity=\"0.3\"></stop>\n            <stop offset=\"100%\" stop-color=\"#c8853a\" stop-opacity=\"0.01\"></stop>\n          </linearGradient>\n          <linearGradient id=\"coldArea\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#4a90d9\" stop-opacity=\"0.2\"></stop>\n            <stop offset=\"100%\" stop-color=\"#4a90d9\" stop-opacity=\"0.01\"></stop>\n          </linearGradient>\n        </defs>\n\n        <!-- Grid -->\n        <line x1=\"50\" y1=\"20\" x2=\"560\" y2=\"20\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"60\" x2=\"560\" y2=\"60\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"100\" x2=\"560\" y2=\"100\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"140\" x2=\"560\" y2=\"140\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"50\" y1=\"180\" x2=\"560\" y2=\"180\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n\n        <!-- Y labels -->\n        <text x=\"42\" y=\"24\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"end\">$550B</text>\n        <text x=\"42\" y=\"64\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"end\">$480B</text>\n        <text x=\"42\" y=\"104\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"end\">$410B</text>\n        <text x=\"42\" y=\"144\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"end\">$340B</text>\n        <text x=\"42\" y=\"184\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"end\">$270B</text>\n\n        <!-- X labels: 2015-2024 (9 intervals, 10 points) -->\n        <!-- x positions: 60, 118, 176, 234, 292, 350, 408, 466, 524 for 2015-2023, 2024 = 560? Let's use 10 points 2015-2024 -->\n        <!-- x = 60 + i*55.5 for i=0..9 -->\n        <!-- Data: 270, 290, 305, 315, 330, 295(covid dip), 345, 390, 450, 495 -->\n\n        <!-- Area fill - Total Market -->\n        <path d=\"M60,184 L115,170 L171,160 L226,154 L282,142 L337,162 L393,126 L448,88 L504,46 L559,26 L559,180 L504,180 L448,180 L393,180 L337,180 L282,180 L226,180 L171,180 L115,180 L60,180 Z\" fill=\"url(#lineArea)\"></path>\n\n        <!-- Total Market Line -->\n        <polyline points=\"60,184 115,170 171,160 226,154 282,142 337,162 393,126 448,88 504,46 559,26\" fill=\"none\" stroke=\"#c8853a\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></polyline>\n\n        <!-- Cold brew sub-trend line -->\n        <polyline points=\"60,178 115,176 171,174 226,170 282,164 337,162 393,150 448,132 504,110 559,88\" fill=\"none\" stroke=\"#4a90d9\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-dasharray=\"5,3\"></polyline>\n\n        <!-- Dots - Total -->\n        <circle cx=\"60\" cy=\"184\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"115\" cy=\"170\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"171\" cy=\"160\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"226\" cy=\"154\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"282\" cy=\"142\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"337\" cy=\"162\" r=\"4\" fill=\"#e85555\"></circle>\n        <circle cx=\"393\" cy=\"126\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"448\" cy=\"88\" r=\"4\" fill=\"#c8853a\"></circle>\n        <circle cx=\"504\" cy=\"46\" r=\"5\" fill=\"#f5c87a\"></circle>\n        <circle cx=\"559\" cy=\"26\" r=\"5\" fill=\"#f5c87a\"></circle>\n\n        <!-- COVID label -->\n        <text x=\"337\" y=\"175\" fill=\"#e85555\" font-size=\"9\" text-anchor=\"middle\">COVID</text>\n\n        <!-- X axis labels -->\n        <text x=\"60\" y=\"200\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"middle\">2015</text>\n        <text x=\"171\" y=\"200\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"middle\">2017</text>\n        <text x=\"282\" y=\"200\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"middle\">2019</text>\n        <text x=\"393\" y=\"200\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"middle\">2021</text>\n        <text x=\"504\" y=\"200\" fill=\"#5a5a78\" font-size=\"10\" text-anchor=\"middle\">2023</text>\n        <text x=\"559\" y=\"200\" fill=\"#9090a8\" font-size=\"10\" text-anchor=\"middle\">2024</text>\n\n        <!-- Legend -->\n        <line x1=\"60\" y1=\"225\" x2=\"90\" y2=\"225\" stroke=\"#c8853a\" stroke-width=\"2.5\"></line>\n        <circle cx=\"75\" cy=\"225\" r=\"3\" fill=\"#c8853a\"></circle>\n        <text x=\"95\" y=\"229\" fill=\"#9090a8\" font-size=\"10\">Total Market</text>\n        <line x1=\"180\" y1=\"225\" x2=\"210\" y2=\"225\" stroke=\"#4a90d9\" stroke-width=\"2\" stroke-dasharray=\"5,3\"></line>\n        <text x=\"215\" y=\"229\" fill=\"#9090a8\" font-size=\"10\">Cold Brew Segment</text>\n\n        <!-- X axis line -->\n        <line x1=\"50\" y1=\"188\" x2=\"560\" y2=\"188\" stroke=\"rgba(200,133,58,0.15)\" stroke-width=\"1\"></line>\n      </svg>",
