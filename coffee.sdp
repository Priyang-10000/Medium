                            "svgText": "<svg width=\"140\" height=\"140\" viewBox=\"0 0 140 140\">\n          <defs>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"></feGaussianBlur>\n              <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n            </filter>\n          </defs>\n          <!-- Background circle -->\n          <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#1f1f2e\" stroke-width=\"22\"></circle>\n\n          <!-- Arabica 60% -->\n          <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#c8842a\" stroke-width=\"22\" stroke-dasharray=\"207.3 138.2\" stroke-dashoffset=\"0\" transform=\"rotate(-90 70 70)\" filter=\"url(#glow)\"></circle>\n          <!-- Robusta 37% -->\n          <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#a78bfa\" stroke-width=\"22\" stroke-dasharray=\"127.8 217.7\" stroke-dashoffset=\"-207.3\" transform=\"rotate(-90 70 70)\"></circle>\n          <!-- Liberica 3% -->\n          <circle cx=\"70\" cy=\"70\" r=\"55\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"22\" stroke-dasharray=\"10.4 334.1\" stroke-dashoffset=\"-335.1\" transform=\"rotate(-90 70 70)\"></circle>\n\n          <!-- Center -->\n          <circle cx=\"70\" cy=\"70\" r=\"38\" fill=\"#1a1a26\"></circle>\n          <text x=\"70\" y=\"65\" text-anchor=\"middle\" fill=\"#f5c469\" font-size=\"18\" font-weight=\"700\" font-family=\"Space Grotesk, sans-serif\">60%</text>\n          <text x=\"70\" y=\"80\" text-anchor=\"middle\" fill=\"#9090b0\" font-size=\"10\" font-family=\"Inter, sans-serif\">Arabica</text>\n        </svg>",
