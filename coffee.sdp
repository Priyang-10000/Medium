                            "field": "",
                            "svgText": "<svg class=\"chart-svg\" viewBox=\"0 0 520 280\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"barGrad1\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n              <stop offset=\"0%\" style=\"stop-color:#f0c060\"></stop>\n              <stop offset=\"100%\" style=\"stop-color:#c8963e\"></stop>\n            </linearGradient>\n            <linearGradient id=\"barGrad2\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n              <stop offset=\"0%\" style=\"stop-color:#e8a840\"></stop>\n              <stop offset=\"100%\" style=\"stop-color:#b07830\"></stop>\n            </linearGradient>\n            <linearGradient id=\"barGrad3\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n              <stop offset=\"0%\" style=\"stop-color:#d09030\"></stop>\n              <stop offset=\"100%\" style=\"stop-color:#986020\"></stop>\n            </linearGradient>\n          </defs>\n          <!-- Grid lines -->\n          <line x1=\"50\" y1=\"20\" x2=\"50\" y2=\"230\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"230\" x2=\"510\" y2=\"230\" stroke=\"#2a2a3e\" stroke-width=\"1\"></line>\n          <line x1=\"50\" y1=\"180\" x2=\"510\" y2=\"180\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"50\" y1=\"130\" x2=\"510\" y2=\"130\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"50\" y1=\"80\" x2=\"510\" y2=\"80\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n          <line x1=\"50\" y1=\"30\" x2=\"510\" y2=\"30\" stroke=\"#2a2a3e\" stroke-width=\"0.5\" stroke-dasharray=\"4,4\"></line>\n          <!-- Y labels -->\n          <text x=\"42\" y=\"234\" fill=\"#6b7280\" font-size=\"10\" text-anchor=\"end\">0</text>\n          <text x=\"42\" y=\"184\" fill=\"#6b7280\" font-size=\"10\" text-anchor=\"end\">20</text>\n          <text x=\"42\" y=\"134\" fill=\"#6b7280\" font-size=\"10\" text-anchor=\"end\">40</text>\n          <text x=\"42\" y=\"84\" fill=\"#6b7280\" font-size=\"10\" text-anchor=\"end\">60</text>\n          <text x=\"42\" y=\"34\" fill=\"#6b7280\" font-size=\"10\" text-anchor=\"end\">80</text>\n          <!-- Bars: Brazil 72, Vietnam 30, Colombia 14, Indonesia 12, Ethiopia 9, Honduras 8 -->\n          <!-- Brazil: 72 → height=180 -->\n          <rect x=\"60\" y=\"50\" width=\"60\" height=\"180\" rx=\"4\" fill=\"url(#barGrad1)\"></rect>\n          <text x=\"90\" y=\"42\" fill=\"#f0c060\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"700\">72M</text>\n          <text x=\"90\" y=\"248\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Brazil</text>\n          <!-- Vietnam: 30 → 75 -->\n          <rect x=\"140\" y=\"155\" width=\"60\" height=\"75\" rx=\"4\" fill=\"url(#barGrad2)\"></rect>\n          <text x=\"170\" y=\"147\" fill=\"#e8a840\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"700\">30M</text>\n          <text x=\"170\" y=\"248\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Vietnam</text>\n          <!-- Colombia: 14 → 35 -->\n          <rect x=\"220\" y=\"195\" width=\"60\" height=\"35\" rx=\"4\" fill=\"url(#barGrad3)\"></rect>\n          <text x=\"250\" y=\"187\" fill=\"#d09030\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"700\">14M</text>\n          <text x=\"250\" y=\"248\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Colombia</text>\n          <!-- Indonesia: 12 → 30 -->\n          <rect x=\"300\" y=\"200\" width=\"60\" height=\"30\" rx=\"4\" fill=\"#986020\"></rect>\n          <text x=\"330\" y=\"192\" fill=\"#b87828\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"700\">12M</text>\n          <text x=\"330\" y=\"248\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Indonesia</text>\n          <!-- Ethiopia: 9 → 22.5 -->\n          <rect x=\"380\" y=\"207\" width=\"60\" height=\"23\" rx=\"4\" fill=\"#804818\"></rect>\n          <text x=\"410\" y=\"199\" fill=\"#a86828\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"700\">9M</text>\n          <text x=\"410\" y=\"248\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Ethiopia</text>\n          <!-- Honduras: 8 → 20 -->\n          <rect x=\"440\" y=\"210\" width=\"60\" height=\"20\" rx=\"4\" fill=\"#603808\"></rect>\n          <text x=\"470\" y=\"202\" fill=\"#885818\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"700\">8M</text>\n          <text x=\"470\" y=\"248\" fill=\"#b8b4ae\" font-size=\"10\" text-anchor=\"middle\">Honduras</text>\n        </svg>",
