                            "field": "",
                            "svgText": "<svg width=\"200\" height=\"200\" viewBox=\"0 0 200 200\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"></feGaussianBlur>\n              <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n            </filter>\n          </defs>\n\n          <!-- Arabica: 60% = 216deg -->\n          <!-- stroke-dasharray: circumference = 2π×70 = 439.8 -->\n          <!-- 60% = 263.9, gap = 175.9 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#1a1a26\" stroke-width=\"32\"></circle>\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#f5c87a\" stroke-width=\"32\" stroke-dasharray=\"263.9 175.9\" stroke-dashoffset=\"0\" transform=\"rotate(-90 100 100)\" filter=\"url(#glow)\"></circle>\n\n          <!-- Robusta: 38% = 136.8deg = 167.1, starts at 263.9 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#c8703a\" stroke-width=\"32\" stroke-dasharray=\"167.1 272.7\" stroke-dashoffset=\"-263.9\" transform=\"rotate(-90 100 100)\"></circle>\n\n          <!-- Liberica: 2% = 7.2deg = 8.8 -->\n          <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#4caf7d\" stroke-width=\"32\" stroke-dasharray=\"8.8 431\" stroke-dashoffset=\"-431\" transform=\"rotate(-90 100 100)\"></circle>\n\n          <!-- Inner -->\n          <circle cx=\"100\" cy=\"100\" r=\"54\" fill=\"#12121a\"></circle>\n          <text x=\"100\" y=\"94\" fill=\"#f5c87a\" font-size=\"26\" font-weight=\"900\" text-anchor=\"middle\" font-family=\"Inter\">60%</text>\n          <text x=\"100\" y=\"112\" fill=\"#9090a8\" font-size=\"11\" text-anchor=\"middle\" font-family=\"Inter\">Arabica</text>\n        </svg>",
