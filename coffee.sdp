                                "field": "",
                                "svgText": "<svg viewBox=\"0 0 200 200\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%; max-width:200px; margin:0 auto; display:block;\">\n            <!-- Arabica: 58% → 208.8° -->\n            <!-- Robusta: 38% → 136.8° -->\n            <!-- Other: 4% → 14.4° -->\n            <!-- Using stroke-dasharray on circle r=70, circumference=439.8 -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#1a1a26\" stroke-width=\"38\"></circle>\n            <!-- Arabica 58% -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#f0c060\" stroke-width=\"38\" stroke-dasharray=\"254.9 184.9\" stroke-dashoffset=\"109.95\" transform=\"rotate(-90,100,100)\"></circle>\n            <!-- Robusta 38% -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#c8963e\" stroke-width=\"38\" stroke-dasharray=\"167.1 272.7\" stroke-dashoffset=\"-144.95\" transform=\"rotate(-90,100,100)\"></circle>\n            <!-- Other 4% -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#5a3e1a\" stroke-width=\"38\" stroke-dasharray=\"17.6 422.2\" stroke-dashoffset=\"-312.05\" transform=\"rotate(-90,100,100)\"></circle>\n            <!-- Center -->\n            <circle cx=\"100\" cy=\"100\" r=\"51\" fill=\"#12121a\"></circle>\n            <text x=\"100\" y=\"96\" fill=\"#f0c060\" font-size=\"22\" font-weight=\"900\" text-anchor=\"middle\" font-family=\"Inter\">58%</text>\n            <text x=\"100\" y=\"112\" fill=\"#6b7280\" font-size=\"10\" text-anchor=\"middle\" font-family=\"Inter\">Arabica</text>\n          </svg>",
