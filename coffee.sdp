                      {
                        "type": "svg",
                        "id": "tag192",
                        "dataset": "",
                        "field": "",
                        "svgText": "<svg width=\"100%\" height=\"200\" viewBox=\"0 0 900 200\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#2dd4bf\" stop-opacity=\"0.4\"></stop>\n            <stop offset=\"100%\" stop-color=\"#2dd4bf\" stop-opacity=\"0\"></stop>\n          </linearGradient>\n          <linearGradient id=\"lineGrad2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#f5c469\" stop-opacity=\"0.4\"></stop>\n            <stop offset=\"100%\" stop-color=\"#f5c469\" stop-opacity=\"0\"></stop>\n          </linearGradient>\n        </defs>\n\n        <!-- Grid lines -->\n        <line x1=\"0\" y1=\"40\" x2=\"900\" y2=\"40\" stroke=\"#2a2a3d\" stroke-width=\"1\" stroke-dasharray=\"6,6\"></line>\n        <line x1=\"0\" y1=\"80\" x2=\"900\" y2=\"80\" stroke=\"#2a2a3d\" stroke-width=\"1\" stroke-dasharray=\"6,6\"></line>\n        <line x1=\"0\" y1=\"120\" x2=\"900\" y2=\"120\" stroke=\"#2a2a3d\" stroke-width=\"1\" stroke-dasharray=\"6,6\"></line>\n        <line x1=\"0\" y1=\"160\" x2=\"900\" y2=\"160\" stroke=\"#2a2a3d\" stroke-width=\"1\" stroke-dasharray=\"6,6\"></line>\n\n        <!-- Y-axis labels -->\n        <text x=\"10\" y=\"44\" fill=\"#6060a0\" font-size=\"14\" font-family=\"Inter\">$650B</text>\n        <text x=\"10\" y=\"84\" fill=\"#6060a0\" font-size=\"14\" font-family=\"Inter\">$550B</text>\n        <text x=\"10\" y=\"124\" fill=\"#6060a0\" font-size=\"14\" font-family=\"Inter\">$450B</text>\n        <text x=\"10\" y=\"164\" fill=\"#6060a0\" font-size=\"14\" font-family=\"Inter\">$350B</text>\n\n        <!-- Area fill: coffee market revenue -->\n        <!-- Points: 2018=$363B, 2019=$390B, 2020=$400B, 2021=$430B, 2022=$462B, 2023=$495B, 2024→2028 projected -->\n        <!-- Mapping: $300B=190, $700B=10, so 1B = (190-10)/(700-300) = 0.45px; y = 190 - (val-300)*0.45 -->\n        <!-- 363→RY=163-0.45*63=190-28=162, x positions: 0,127,254,381,508,635,762,889 for 8 years (2018-2025) -->\n\n        <polygon points=\"70,172 196,160 322,155 448,141 574,126 700,108 780,94 870,76 870,190 70,190\" fill=\"url(#lineGrad)\"></polygon>\n\n        <!-- Line actual -->\n        <polyline points=\"70,172 196,160 322,155 448,141 574,126 700,108\" fill=\"none\" stroke=\"#2dd4bf\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></polyline>\n\n        <!-- Line projected (dashed) -->\n        <polyline points=\"700,108 780,94 870,76\" fill=\"none\" stroke=\"#2dd4bf\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-dasharray=\"8,5\" opacity=\"0.7\"></polyline>\n\n        <!-- Data points actual -->\n        <circle cx=\"70\" cy=\"172\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\"></circle>\n        <circle cx=\"196\" cy=\"160\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\"></circle>\n        <circle cx=\"322\" cy=\"155\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\"></circle>\n        <circle cx=\"448\" cy=\"141\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\"></circle>\n        <circle cx=\"574\" cy=\"126\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\"></circle>\n        <circle cx=\"700\" cy=\"108\" r=\"7\" fill=\"#f5c469\" stroke=\"#0a0a0f\" stroke-width=\"2\"></circle>\n\n        <!-- Projected points -->\n        <circle cx=\"780\" cy=\"94\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\" opacity=\"0.7\"></circle>\n        <circle cx=\"870\" cy=\"76\" r=\"5\" fill=\"#2dd4bf\" stroke=\"#0a0a0f\" stroke-width=\"2\" opacity=\"0.7\"></circle>\n\n        <!-- Labels above points -->\n        <text x=\"55\" y=\"165\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">$363B</text>\n        <text x=\"181\" y=\"153\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">$390B</text>\n        <text x=\"307\" y=\"148\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">$400B</text>\n        <text x=\"433\" y=\"134\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">$430B</text>\n        <text x=\"559\" y=\"119\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">$462B</text>\n        <text x=\"678\" y=\"100\" fill=\"#f5c469\" font-size=\"14\" font-weight=\"bold\" font-family=\"Inter\">$495B</text>\n        <text x=\"756\" y=\"86\" fill=\"#6060a0\" font-size=\"13\" font-family=\"Inter\">$540B</text>\n        <text x=\"844\" y=\"68\" fill=\"#6060a0\" font-size=\"13\" font-family=\"Inter\">$635B</text>\n\n        <!-- X-axis labels -->\n        <text x=\"60\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2018</text>\n        <text x=\"186\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2019</text>\n        <text x=\"312\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2020</text>\n        <text x=\"438\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2021</text>\n        <text x=\"564\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2022</text>\n        <text x=\"690\" y=\"195\" fill=\"#f5c469\" font-size=\"13\" text-anchor=\"middle\" font-weight=\"bold\" font-family=\"Inter\">2023</text>\n        <text x=\"770\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2025★</text>\n        <text x=\"860\" y=\"195\" fill=\"#6060a0\" font-size=\"13\" text-anchor=\"middle\" font-family=\"Inter\">2028★</text>\n\n        <!-- Legend -->\n        <line x1=\"620\" y1=\"18\" x2=\"648\" y2=\"18\" stroke=\"#2dd4bf\" stroke-width=\"3\"></line>\n        <circle cx=\"634\" cy=\"18\" r=\"4\" fill=\"#2dd4bf\"></circle>\n        <text x=\"654\" y=\"23\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">Actual</text>\n        <line x1=\"720\" y1=\"18\" x2=\"748\" y2=\"18\" stroke=\"#2dd4bf\" stroke-width=\"3\" stroke-dasharray=\"6,4\"></line>\n        <text x=\"754\" y=\"23\" fill=\"#9090b0\" font-size=\"13\" font-family=\"Inter\">Projected ★</text>\n      </svg>",
