                            "field": "",
                            "svgText": "<svg width=\"160\" height=\"160\" viewBox=\"0 0 160 160\" class=\"donut-svg\">\n        <!-- Donut: confectionery 47%, food&bev 23%, cosmetics 12%, pharma 8%, other 10% -->\n        <!-- r=58, circumference=364.4 -->\n        <!-- confectionery: 47% = 171.3, offset=0 -->\n        <!-- food&bev: 23% = 83.8, offset=171.3 -->\n        <!-- cosmetics: 12% = 43.7, offset=255.1 -->\n        <!-- pharma: 8% = 29.2, offset=298.8 -->\n        <!-- other: 10% = 36.4, offset=328 -->\n        <circle cx=\"80\" cy=\"80\" r=\"58\" fill=\"none\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"28\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"58\" fill=\"none\" stroke=\"#d4813a\" stroke-width=\"28\" stroke-dasharray=\"171.3 193.1\" stroke-dashoffset=\"0\" transform=\"rotate(-90 80 80)\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"58\" fill=\"none\" stroke=\"#27ae60\" stroke-width=\"28\" stroke-dasharray=\"83.8 280.6\" stroke-dashoffset=\"-171.3\" transform=\"rotate(-90 80 80)\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"58\" fill=\"none\" stroke=\"#9b59b6\" stroke-width=\"28\" stroke-dasharray=\"43.7 320.7\" stroke-dashoffset=\"-255.1\" transform=\"rotate(-90 80 80)\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"58\" fill=\"none\" stroke=\"#16a085\" stroke-width=\"28\" stroke-dasharray=\"29.2 335.2\" stroke-dashoffset=\"-298.8\" transform=\"rotate(-90 80 80)\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"58\" fill=\"none\" stroke=\"#f0c040\" stroke-width=\"28\" stroke-dasharray=\"36.4 328\" stroke-dashoffset=\"-328\" transform=\"rotate(-90 80 80)\"></circle>\n        <circle cx=\"80\" cy=\"80\" r=\"44\" fill=\"var(--card)\"></circle>\n        <text x=\"80\" y=\"76\" text-anchor=\"middle\" font-size=\"18\" font-weight=\"900\" fill=\"#d4813a\" font-family=\"'Playfair Display',serif\">47%</text>\n        <text x=\"80\" y=\"91\" text-anchor=\"middle\" font-size=\"9\" fill=\"#8888aa\">Confectionery</text>\n      </svg>",
