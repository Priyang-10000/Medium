                            "id": "tag90",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg viewBox=\"0 0 520 140\" class=\"line-svg\" style=\"height:140px;\">\n        <!-- grid lines -->\n        <line x1=\"40\" y1=\"10\" x2=\"510\" y2=\"10\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"40\" x2=\"510\" y2=\"40\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"70\" x2=\"510\" y2=\"70\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <line x1=\"40\" y1=\"100\" x2=\"510\" y2=\"100\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></line>\n        <!-- y labels -->\n        <text x=\"2\" y=\"14\" font-size=\"8\" fill=\"#666688\">$12k</text>\n        <text x=\"2\" y=\"44\" font-size=\"8\" fill=\"#666688\">$9k</text>\n        <text x=\"2\" y=\"74\" font-size=\"8\" fill=\"#666688\">$6k</text>\n        <text x=\"2\" y=\"104\" font-size=\"8\" fill=\"#666688\">$3k</text>\n        <!-- base line -->\n        <line x1=\"40\" y1=\"120\" x2=\"510\" y2=\"120\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"></line>\n        <!-- data: normalize to 0–110px (12906 max)\n             2019~2350 → y≈100, 2021~2700→y≈97, 2023~4200→y≈84, Apr24~12220→y≈14, Dec24~12906→y≈10, Mar26~3389→y≈91\n             x positions: 40,120,210,320,395,510 -->\n        <defs>\n          <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0%\" stop-color=\"#27ae60\"></stop>\n            <stop offset=\"50%\" stop-color=\"#e74c3c\"></stop>\n            <stop offset=\"100%\" stop-color=\"#27ae60\"></stop>\n          </linearGradient>\n          <linearGradient id=\"areaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"rgba(212,129,58,0.25)\"></stop>\n            <stop offset=\"100%\" stop-color=\"rgba(212,129,58,0)\"></stop>\n          </linearGradient>\n        </defs>\n        <path d=\"M40,100 L120,97 L210,84 L320,14 L395,10 L510,91\" fill=\"url(#areaGrad)\" stroke=\"none\"></path>\n        <path d=\"M40,120 L40,100 L120,97 L210,84 L320,14 L395,10 L510,91 L510,120 Z\" fill=\"url(#areaGrad)\"></path>\n        <path d=\"M40,100 L120,97 L210,84 L320,14 L395,10 L510,91\" fill=\"none\" stroke=\"url(#lineGrad)\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n        <!-- dots -->\n        <circle cx=\"40\" cy=\"100\" r=\"4\" fill=\"#27ae60\"></circle>\n        <circle cx=\"120\" cy=\"97\" r=\"4\" fill=\"#27ae60\"></circle>\n        <circle cx=\"210\" cy=\"84\" r=\"4\" fill=\"#e67e22\"></circle>\n        <circle cx=\"320\" cy=\"14\" r=\"5\" fill=\"#e74c3c\"></circle>\n        <circle cx=\"395\" cy=\"10\" r=\"6\" fill=\"#c0392b\" stroke=\"#ff6b6b\" stroke-width=\"1.5\"></circle>\n        <circle cx=\"510\" cy=\"91\" r=\"4\" fill=\"#27ae60\"></circle>\n        <!-- ATH label -->\n        <text x=\"400\" y=\"8\" font-size=\"8\" fill=\"#e74c3c\" font-weight=\"bold\">ATH</text>\n        <!-- x labels -->\n        <text x=\"36\" y=\"133\" font-size=\"7.5\" fill=\"#666688\">2019</text>\n        <text x=\"116\" y=\"133\" font-size=\"7.5\" fill=\"#666688\">2021</text>\n        <text x=\"206\" y=\"133\" font-size=\"7.5\" fill=\"#666688\">2023</text>\n        <text x=\"308\" y=\"133\" font-size=\"7.5\" fill=\"#666688\">Apr'24</text>\n        <text x=\"382\" y=\"133\" font-size=\"7.5\" fill=\"#666688\">Dec'24</text>\n        <text x=\"496\" y=\"133\" font-size=\"7.5\" fill=\"#666688\">Now</text>\n      </svg>",
