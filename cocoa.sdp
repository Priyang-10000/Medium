                          {
                            "type": "svg",
                            "id": "tag79",
                            "dataset": "",
                            "field": "",
                            "svgText": "<svg width=\"100%\" height=\"200\" viewBox=\"0 0 560 200\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#d4a843\" stop-opacity=\"0.35\"></stop>\n              <stop offset=\"100%\" stop-color=\"#d4a843\" stop-opacity=\"0\"></stop>\n            </linearGradient>\n            <linearGradient id=\"lineStroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#8b5e3c\"></stop>\n              <stop offset=\"60%\" stop-color=\"#d4a843\"></stop>\n              <stop offset=\"100%\" stop-color=\"#ef4444\"></stop>\n            </linearGradient>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"2\" result=\"coloredBlur\"></feGaussianBlur>\n              <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n            </filter>\n          </defs>\n\n          <!-- Grid lines -->\n          <line x1=\"0\" y1=\"30\" x2=\"560\" y2=\"30\" stroke=\"var(--border)\" stroke-width=\"0.5\"></line>\n          <line x1=\"0\" y1=\"70\" x2=\"560\" y2=\"70\" stroke=\"var(--border)\" stroke-width=\"0.5\"></line>\n          <line x1=\"0\" y1=\"110\" x2=\"560\" y2=\"110\" stroke=\"var(--border)\" stroke-width=\"0.5\"></line>\n          <line x1=\"0\" y1=\"150\" x2=\"560\" y2=\"150\" stroke=\"var(--border)\" stroke-width=\"0.5\"></line>\n          <line x1=\"0\" y1=\"185\" x2=\"560\" y2=\"185\" stroke=\"var(--border)\" stroke-width=\"0.5\"></line>\n\n          <!-- Y-axis labels -->\n          <text x=\"4\" y=\"28\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">12,000</text>\n          <text x=\"4\" y=\"68\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">9,000</text>\n          <text x=\"4\" y=\"108\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">6,000</text>\n          <text x=\"4\" y=\"148\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">3,000</text>\n          <text x=\"4\" y=\"184\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">1,000</text>\n\n          <!-- Data path: approximate points\n               2020 Jan ~2400 → Apr ~2200 → 2021 Jan ~2600 → 2022 Jan ~2700 → \n               2023 Jan ~2800 → Jul ~3400 → 2024 Jan ~4200 → Apr ~10000 → Dec ~12906 →\n               2025 Mar ~8000 → Jun ~5000 → 2026 Jan ~4500 → Mar ~3290\n               Scale: x=0→560 maps 2020Jan→2026Mar; y: 0=13000, 185=800\n               y = 185 - (val-800)/(12200)*185\n          -->\n          <!-- Area fill -->\n          <path d=\"\n            M 0,163\n            L 30,166\n            L 70,165\n            L 110,162\n            L 160,160\n            L 200,158\n            L 230,155\n            L 260,148\n            L 300,112\n            L 330,55\n            L 360,22\n            L 390,18\n            L 420,58\n            L 450,95\n            L 490,110\n            L 530,145\n            L 560,150\n            L 560,185 L 0,185 Z\n          \" fill=\"url(#lineGrad)\"></path>\n\n          <!-- Line -->\n          <path d=\"\n            M 0,163\n            L 30,166\n            L 70,165\n            L 110,162\n            L 160,160\n            L 200,158\n            L 230,155\n            L 260,148\n            L 300,112\n            L 330,55\n            L 360,22\n            L 390,18\n            L 420,58\n            L 450,95\n            L 490,110\n            L 530,145\n            L 560,150\n          \" fill=\"none\" stroke=\"url(#lineStroke)\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" filter=\"url(#glow)\"></path>\n\n          <!-- ATH dot -->\n          <circle cx=\"390\" cy=\"18\" r=\"5\" fill=\"#ef4444\" filter=\"url(#glow)\"></circle>\n          <text x=\"395\" y=\"14\" fill=\"#ef4444\" font-size=\"8\" font-family=\"Space Grotesk,sans-serif\" font-weight=\"700\">ATH $12,906</text>\n          <text x=\"395\" y=\"24\" fill=\"#5a5470\" font-size=\"7\" font-family=\"Inter,sans-serif\">Dec 2024</text>\n\n          <!-- Current dot -->\n          <circle cx=\"560\" cy=\"150\" r=\"5\" fill=\"#d4a843\" filter=\"url(#glow)\"></circle>\n\n          <!-- X-axis labels -->\n          <text x=\"0\" y=\"198\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">2020</text>\n          <text x=\"100\" y=\"198\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">2021</text>\n          <text x=\"210\" y=\"198\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">2022</text>\n          <text x=\"310\" y=\"198\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">2023</text>\n          <text x=\"390\" y=\"198\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">2024</text>\n          <text x=\"490\" y=\"198\" fill=\"#5a5470\" font-size=\"8\" font-family=\"Inter,sans-serif\">2025</text>\n          <text x=\"535\" y=\"198\" fill=\"#d4a843\" font-size=\"8\" font-family=\"Inter,sans-serif\" font-weight=\"700\">'26</text>\n        </svg>",
                            "record": 0,
