                                    "dataset": "",
                                    "field": "",
                                    "svgText": "<svg width=\"200\" height=\"130\" viewBox=\"0 0 200 130\">\n              <!-- Simplified Africa silhouette hint -->\n              <rect x=\"10\" y=\"5\" width=\"180\" height=\"120\" rx=\"8\" fill=\"rgba(26,26,38,0.8)\" stroke=\"var(--border)\" stroke-width=\"1\"></rect>\n              <text x=\"100\" y=\"20\" text-anchor=\"middle\" fill=\"rgba(160,160,192,0.4)\" font-size=\"9\" font-weight=\"600\">WEST AFRICA — COCOA BELT</text>\n\n              <!-- Côte d'Ivoire block -->\n              <rect x=\"20\" y=\"35\" width=\"70\" height=\"50\" rx=\"6\" fill=\"rgba(200,134,10,0.25)\" stroke=\"#e8a020\" stroke-width=\"1.5\"></rect>\n              <text x=\"55\" y=\"55\" text-anchor=\"middle\" fill=\"#e8a020\" font-size=\"9\" font-weight=\"700\">Côte d'Ivoire</text>\n              <text x=\"55\" y=\"68\" text-anchor=\"middle\" fill=\"#f5c842\" font-size=\"11\" font-weight=\"900\">~40%</text>\n              <text x=\"55\" y=\"79\" text-anchor=\"middle\" fill=\"rgba(160,160,192,0.6)\" font-size=\"8\">World's Largest</text>\n\n              <!-- Ghana block -->\n              <rect x=\"100\" y=\"35\" width=\"55\" height=\"50\" rx=\"6\" fill=\"rgba(46,204,113,0.15)\" stroke=\"#2ecc71\" stroke-width=\"1.5\"></rect>\n              <text x=\"127\" y=\"55\" text-anchor=\"middle\" fill=\"#2ecc71\" font-size=\"9\" font-weight=\"700\">Ghana</text>\n              <text x=\"127\" y=\"68\" text-anchor=\"middle\" fill=\"#2ecc71\" font-size=\"11\" font-weight=\"900\">~20%</text>\n              <text x=\"127\" y=\"79\" text-anchor=\"middle\" fill=\"rgba(160,160,192,0.6)\" font-size=\"8\">2nd Largest</text>\n\n              <!-- Combined label -->\n              <rect x=\"15\" y=\"96\" width=\"170\" height=\"22\" rx=\"5\" fill=\"rgba(231,76,60,0.1)\" stroke=\"rgba(231,76,60,0.3)\" stroke-width=\"1\"></rect>\n              <text x=\"100\" y=\"111\" text-anchor=\"middle\" fill=\"#e74c3c\" font-size=\"9\" font-weight=\"700\">COMBINED: ~60% OF GLOBAL SUPPLY — HIGH WEATHER RISK</text>\n            </svg>",
