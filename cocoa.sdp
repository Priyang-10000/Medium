                                "svgText": "<svg class=\"donut-svg\" viewBox=\"0 0 200 200\">\n            <defs>\n              <filter id=\"glow\">\n                <feGaussianBlur stdDeviation=\"2\" result=\"coloredBlur\"></feGaussianBlur>\n                <feMerge><feMergeNode in=\"coloredBlur\"></feMergeNode><feMergeNode in=\"SourceGraphic\"></feMergeNode></feMerge>\n              </filter>\n            </defs>\n\n            <!-- Asia-Pacific 27% → stroke-dasharray=169.6, offset=0 -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#3498db\" stroke-width=\"28\" stroke-dasharray=\"169.6 270.4\" stroke-dashoffset=\"0\" transform=\"rotate(-90 100 100)\"></circle>\n\n            <!-- North America 35% → 219.9, offset=-169.6 -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#e8a020\" stroke-width=\"28\" stroke-dasharray=\"219.9 220.1\" stroke-dashoffset=\"-169.6\" transform=\"rotate(-90 100 100)\"></circle>\n\n            <!-- Europe 20% → 125.7, offset=-389.5 -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#2ecc71\" stroke-width=\"28\" stroke-dasharray=\"125.7 314.3\" stroke-dashoffset=\"-389.5\" transform=\"rotate(-90 100 100)\"></circle>\n\n            <!-- Middle East & Africa 8% → 50.3, offset=-515.2 -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#9b59b6\" stroke-width=\"28\" stroke-dasharray=\"50.3 389.7\" stroke-dashoffset=\"-515.2\" transform=\"rotate(-90 100 100)\"></circle>\n\n            <!-- Rest 10% → 62.8, offset=-565.5 -->\n            <circle cx=\"100\" cy=\"100\" r=\"70\" fill=\"none\" stroke=\"#606080\" stroke-width=\"28\" stroke-dasharray=\"62.8 377.2\" stroke-dashoffset=\"-565.5\" transform=\"rotate(-90 100 100)\"></circle>\n\n            <!-- Center -->\n            <circle cx=\"100\" cy=\"100\" r=\"46\" fill=\"#1a1a26\"></circle>\n            <text x=\"100\" y=\"93\" text-anchor=\"middle\" fill=\"#e8e8f0\" font-size=\"13\" font-weight=\"800\">Global</text>\n            <text x=\"100\" y=\"108\" text-anchor=\"middle\" fill=\"#a0a0c0\" font-size=\"10\">Demand</text>\n            <text x=\"100\" y=\"120\" text-anchor=\"middle\" fill=\"#e8a020\" font-size=\"11\" font-weight=\"700\">2026</text>\n          </svg>",
