                                "id": "tag33",
                                "dataset": "",
                                "field": "",
                                "svgText": "<svg viewBox=\"0 0 500 200\" preserveAspectRatio=\"none\">\n            <!-- Grid lines -->\n            <line x1=\"0\" y1=\"40\" x2=\"500\" y2=\"40\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n            <line x1=\"0\" y1=\"80\" x2=\"500\" y2=\"80\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n            <line x1=\"0\" y1=\"120\" x2=\"500\" y2=\"120\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n            <line x1=\"0\" y1=\"160\" x2=\"500\" y2=\"160\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"></line>\n\n            <!-- Price labels -->\n            <text x=\"5\" y=\"38\" fill=\"rgba(160,160,192,0.5)\" font-size=\"9\">$11K</text>\n            <text x=\"5\" y=\"78\" fill=\"rgba(160,160,192,0.5)\" font-size=\"9\">$9K</text>\n            <text x=\"5\" y=\"118\" fill=\"rgba(160,160,192,0.5)\" font-size=\"9\">$6K</text>\n            <text x=\"5\" y=\"158\" fill=\"rgba(160,160,192,0.5)\" font-size=\"9\">$3K</text>\n\n            <!-- Gradient fill -->\n            <defs>\n              <linearGradient id=\"priceGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#e8a020\" stop-opacity=\"0.35\"></stop>\n                <stop offset=\"100%\" stop-color=\"#e8a020\" stop-opacity=\"0.02\"></stop>\n              </linearGradient>\n              <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n                <stop offset=\"0%\" stop-color=\"#7b4f2e\"></stop>\n                <stop offset=\"60%\" stop-color=\"#e8a020\"></stop>\n                <stop offset=\"100%\" stop-color=\"#f5c842\"></stop>\n              </linearGradient>\n            </defs>\n\n            <!-- Area fill: 2020≈$2400→y=168, 2021≈$2600→y=162, 2022≈$2400→y=168,\n                 2023≈$3500→y=142, 2024 peak≈$10800→y=15, 2025≈$9000→y=80, 2026≈$8500→y=95 -->\n            <path d=\"M30,168 L110,162 L200,168 L290,142 L380,15 L440,80 L490,95 L490,200 L30,200 Z\" fill=\"url(#priceGrad)\"></path>\n\n            <!-- Line -->\n            <polyline points=\"30,168 110,162 200,168 290,142 380,15 440,80 490,95\" fill=\"none\" stroke=\"url(#lineGrad)\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></polyline>\n\n            <!-- Data points -->\n            <circle cx=\"30\" cy=\"168\" r=\"4\" fill=\"#7b4f2e\" stroke=\"#e8a020\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"110\" cy=\"162\" r=\"4\" fill=\"#7b4f2e\" stroke=\"#e8a020\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"200\" cy=\"168\" r=\"4\" fill=\"#7b4f2e\" stroke=\"#e8a020\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"290\" cy=\"142\" r=\"4\" fill=\"#a0623a\" stroke=\"#e8a020\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"380\" cy=\"15\" r=\"6\" fill=\"#e8a020\" stroke=\"#f5c842\" stroke-width=\"2\"></circle>\n            <circle cx=\"440\" cy=\"80\" r=\"5\" fill=\"#c8860a\" stroke=\"#f5c842\" stroke-width=\"1.5\"></circle>\n            <circle cx=\"490\" cy=\"95\" r=\"4\" fill=\"#c8860a\" stroke=\"#f5c842\" stroke-width=\"1.5\"></circle>\n\n            <!-- Peak label -->\n            <rect x=\"350\" y=\"2\" width=\"65\" height=\"16\" rx=\"4\" fill=\"rgba(231,76,60,0.2)\"></rect>\n            <text x=\"383\" y=\"13\" fill=\"#e74c3c\" font-size=\"9\" text-anchor=\"middle\" font-weight=\"700\">PEAK $10.8K</text>\n\n            <!-- Year labels -->\n            <text x=\"30\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2020</text>\n            <text x=\"110\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2021</text>\n            <text x=\"200\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2022</text>\n            <text x=\"290\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2023</text>\n            <text x=\"380\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2024</text>\n            <text x=\"440\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2025</text>\n            <text x=\"490\" y=\"195\" fill=\"rgba(160,160,192,0.6)\" font-size=\"9\" text-anchor=\"middle\">2026</text>\n          </svg>",
