                    "id": "tag21",
                    "dataset": "",
                    "field": "",
                    "svgText": "<svg class=\"hero-svg\" viewBox=\"0 0 220 280\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <!-- Background glow -->\n      <ellipse cx=\"110\" cy=\"140\" rx=\"90\" ry=\"110\" fill=\"url(#heroGlow)\"></ellipse>\n      <!-- Pod body -->\n      <ellipse cx=\"110\" cy=\"155\" rx=\"62\" ry=\"85\" fill=\"url(#podGrad)\"></ellipse>\n      <ellipse cx=\"110\" cy=\"155\" rx=\"62\" ry=\"85\" fill=\"none\" stroke=\"url(#podStroke)\" stroke-width=\"1.5\"></ellipse>\n      <!-- Pod ridges -->\n      <path d=\"M70 110 Q75 155 70 200\" stroke=\"rgba(212,168,67,0.3)\" stroke-width=\"1.5\" fill=\"none\"></path>\n      <path d=\"M82 90 Q87 155 82 218\" stroke=\"rgba(212,168,67,0.25)\" stroke-width=\"1.5\" fill=\"none\"></path>\n      <path d=\"M110 82 Q115 155 110 228\" stroke=\"rgba(212,168,67,0.3)\" stroke-width=\"1.5\" fill=\"none\"></path>\n      <path d=\"M138 90 Q133 155 138 218\" stroke=\"rgba(212,168,67,0.25)\" stroke-width=\"1.5\" fill=\"none\"></path>\n      <path d=\"M150 110 Q145 155 150 200\" stroke=\"rgba(212,168,67,0.2)\" stroke-width=\"1.5\" fill=\"none\"></path>\n      <!-- Stem -->\n      <path d=\"M110 82 C110 70 115 55 108 38 C104 25 112 15 118 22\" stroke=\"#8b5e3c\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"></path>\n      <!-- Leaf -->\n      <path d=\"M118 22 C130 10 148 18 142 32 C138 42 122 38 118 22Z\" fill=\"url(#leafGrad)\" opacity=\"0.9\"></path>\n      <!-- Leaf vein -->\n      <path d=\"M118 22 C130 25 140 28 142 32\" stroke=\"rgba(34,197,94,0.4)\" stroke-width=\"0.8\" fill=\"none\"></path>\n      <!-- Shine -->\n      <ellipse cx=\"88\" cy=\"130\" rx=\"12\" ry=\"22\" fill=\"rgba(255,255,255,0.06)\" transform=\"rotate(-15 88 130)\"></ellipse>\n      <!-- Bean shapes inside -->\n      <ellipse cx=\"96\" cy=\"155\" rx=\"8\" ry=\"11\" fill=\"url(#beanGrad)\" opacity=\"0.6\"></ellipse>\n      <ellipse cx=\"110\" cy=\"165\" rx=\"8\" ry=\"11\" fill=\"url(#beanGrad)\" opacity=\"0.6\"></ellipse>\n      <ellipse cx=\"124\" cy=\"155\" rx=\"8\" ry=\"11\" fill=\"url(#beanGrad)\" opacity=\"0.6\"></ellipse>\n      <!-- Floating beans around pod -->\n      <ellipse cx=\"30\" cy=\"80\" rx=\"10\" ry=\"14\" fill=\"url(#beanGrad2)\" opacity=\"0.8\" transform=\"rotate(-20 30 80)\"></ellipse>\n      <ellipse cx=\"185\" cy=\"200\" rx=\"9\" ry=\"13\" fill=\"url(#beanGrad2)\" opacity=\"0.7\" transform=\"rotate(15 185 200)\"></ellipse>\n      <ellipse cx=\"20\" cy=\"185\" rx=\"7\" ry=\"10\" fill=\"url(#beanGrad2)\" opacity=\"0.5\" transform=\"rotate(-10 20 185)\"></ellipse>\n      <ellipse cx=\"195\" cy=\"100\" rx=\"8\" ry=\"11\" fill=\"url(#beanGrad2)\" opacity=\"0.6\" transform=\"rotate(25 195 100)\"></ellipse>\n      <!-- Stars / particles -->\n      <circle cx=\"50\" cy=\"50\" r=\"1.5\" fill=\"#d4a843\" opacity=\"0.6\"></circle>\n      <circle cx=\"170\" cy=\"60\" r=\"1\" fill=\"#d4a843\" opacity=\"0.4\"></circle>\n      <circle cx=\"40\" cy=\"220\" r=\"1.5\" fill=\"#d4a843\" opacity=\"0.5\"></circle>\n      <circle cx=\"180\" cy=\"250\" r=\"1\" fill=\"#d4a843\" opacity=\"0.3\"></circle>\n      <circle cx=\"200\" cy=\"145\" r=\"2\" fill=\"#8b5e3c\" opacity=\"0.5\"></circle>\n\n      <defs>\n        <radialGradient id=\"heroGlow\" cx=\"50%\" cy=\"50%\">\n          <stop offset=\"0%\" stop-color=\"#d4a843\" stop-opacity=\"0.12\"></stop>\n          <stop offset=\"100%\" stop-color=\"#d4a843\" stop-opacity=\"0\"></stop>\n        </radialGradient>\n        <linearGradient id=\"podGrad\" x1=\"60\" y1=\"80\" x2=\"160\" y2=\"240\" gradientUnits=\"userSpaceOnUse\">\n          <stop offset=\"0%\" stop-color=\"#5c3320\"></stop>\n          <stop offset=\"50%\" stop-color=\"#3d1f0e\"></stop>\n          <stop offset=\"100%\" stop-color=\"#2a1408\"></stop>\n        </linearGradient>\n        <linearGradient id=\"podStroke\" x1=\"60\" y1=\"80\" x2=\"160\" y2=\"240\" gradientUnits=\"userSpaceOnUse\">\n          <stop offset=\"0%\" stop-color=\"#d4a843\"></stop>\n          <stop offset=\"100%\" stop-color=\"#8b5e3c\"></stop>\n        </linearGradient>\n        <linearGradient id=\"leafGrad\" x1=\"118\" y1=\"12\" x2=\"142\" y2=\"35\" gradientUnits=\"userSpaceOnUse\">\n          <stop offset=\"0%\" stop-color=\"#22c55e\"></stop>\n          <stop offset=\"100%\" stop-color=\"#166534\"></stop>\n        </linearGradient>\n        <linearGradient id=\"beanGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" gradientUnits=\"objectBoundingBox\">\n          <stop offset=\"0%\" stop-color=\"#8b5e3c\"></stop>\n          <stop offset=\"100%\" stop-color=\"#3d1f0e\"></stop>\n        </linearGradient>\n        <linearGradient id=\"beanGrad2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\" gradientUnits=\"objectBoundingBox\">\n          <stop offset=\"0%\" stop-color=\"#c4863a\"></stop>\n          <stop offset=\"100%\" stop-color=\"#5c3320\"></stop>\n        </linearGradient>\n      </defs>\n    </svg>",
